<file path="sql/create_listing_saves_table.sql">
-- =====================================================
-- TICKET F: Tabla listing_saves (wishlist) + RLS
-- =====================================================

-- 1. Crear tabla listing_saves
CREATE TABLE IF NOT EXISTS public.listing_saves (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  listing_id UUID NOT NULL REFERENCES public.listings(id) ON DELETE CASCADE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  UNIQUE(user_id, listing_id)
);

-- 2. Habilitar Row Level Security (RLS)
ALTER TABLE public.listing_saves ENABLE ROW LEVEL SECURITY;

-- 3. Crear polГӯticas RLS

-- PolГӯtica SELECT: Solo el dueГұo puede ver sus saves
CREATE POLICY "Users can view their own saves"
ON public.listing_saves
FOR SELECT
USING (auth.uid() = user_id);

-- PolГӯtica INSERT: Solo el dueГұo puede crear sus saves
CREATE POLICY "Users can insert their own saves"
ON public.listing_saves
FOR INSERT
WITH CHECK (auth.uid() = user_id);

-- PolГӯtica DELETE: Solo el dueГұo puede eliminar sus saves
CREATE POLICY "Users can delete their own saves"
ON public.listing_saves
FOR DELETE
