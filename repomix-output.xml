const sortedThreads = threadsWithData.sort((a, b) => {
  const aDate = a.lastMessage?.created_at || a.created_at
  const bDate = b.lastMessage?.created_at || b.created_at
  return new Date(bDate).getTime() - new Date(aDate).getTime()
})
```

