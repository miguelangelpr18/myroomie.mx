                        )}
                        {isFeatured && listing.featured_until && (
                          <p className="text-xs text-orange-700 mt-2">
                            Destacado hasta:{' '}
                            {new Date(listing.featured_until).toLocaleDateString('es-MX', {
                              year: 'numeric',
                              month: 'short',
                              day: 'numeric',
                            })}
